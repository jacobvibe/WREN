# ============================================================================
# WREN — Environment variable template
# ============================================================================
# SECURITY WARNING:
#   Copy this file to `.env` and fill in real values. NEVER commit `.env` —
#   it is gitignored. It contains live secrets (Supabase keys, the Remove.bg
#   API key, and a Google Cloud service-account private key). If `.env` is ever
#   committed or pushed, treat every key below as compromised and rotate it.
# ============================================================================

# ── Client app (Expo) — bundled into the app, must be EXPO_PUBLIC_ prefixed ──

# Supabase project URL.  Dashboard → Project Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to ship — RLS enforces access).
# Dashboard → Project Settings → API → Project API keys → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth *web* client ID (used by @react-native-google-signin on native).
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs →
# the "Web application" client. Format: <id>.apps.googleusercontent.com
# TODO: set the real Google OAuth client ID before release — a placeholder here
#       makes Google Sign In fail on device (Apple Sign In still works).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Cloudflare Turnstile site key — bot-protection widget.
# Cloudflare dashboard → Turnstile → your WREN widget → Site key
EXPO_PUBLIC_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key

# ── Supabase Edge Function secrets ──────────────────────────────────────────
# These are NOT read by the client app. Set them with:
#   supabase secrets set KEY=value
# (or Dashboard → Edge Functions → Secrets). Listed here for completeness.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into the Edge Function runtime by Supabase — do not set manually.

# Remove.bg API key — background removal. https://www.remove.bg/dashboard#api-key
# TODO: ROTATE — the previously committed key is considered compromised.
REMOVE_BG_API_KEY=your-remove-bg-api-key

# Google Cloud Vision service-account JSON (single line or escaped multiline).
# Google Cloud Console → IAM & Admin → Service Accounts → Keys → Add key (JSON).
# TODO: ROTATE the service-account key if it was ever committed.
GOOGLE_VISION_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# AWIN publisher/affiliate ID — affiliate click attribution.
# AWIN dashboard → Account → Account details → Publisher ID.
AWIN_PUBLISHER_ID=your-awin-publisher-id

# ── Build-time (waitlist static site, scripts/) ─────────────────────────────
# Used by waitlist/build.js and the spike scripts. Same values as the
# EXPO_PUBLIC_ Supabase pair above, without the EXPO_PUBLIC_ prefix.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
