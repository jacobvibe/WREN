{
  "expo": {
    "name": "Wren",
    "slug": "wren-app",
    "scheme": "wren-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wrenapp.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Wren needs your camera to photograph clothing items for your wardrobe.",
        "NSPhotoLibraryUsageDescription": "Wren needs access to your photos to add clothing items to your wardrobe."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.wrenapp.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wren needs your photo library to add clothing items.",
          "cameraPermission": "Wren needs your camera to photograph clothing items.",
          "microphonePermission": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.71865721804-tlffd0v5ohe72f2gs1nsiivsn2mgdveo"
        }
      ],
      "@sentry/react-native",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "wren-7k"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "07c433f1-896f-4e00-a929-fedbc9bdce7b"
      }
    },
    "owner": "jacobvibe"
  }
}
